rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // =========================================================================
    // MOTORS COLLECTION (Katalog)
    // =========================================================================
    match /motors/{motorId} {
      // Allowed for public (demo purposes to support client-side hardcoded auth)
      allow read, write: if true;
    }

    // =========================================================================
    // TRANSACTIONS COLLECTION (Booking & Kredit)
    // =========================================================================
    match /transactions/{transactionId} {
      // Allowed for public (demo purposes to support client-side hardcoded auth)
      allow read, write: if true;
    }
  }
}
